# JIRA MCP Server Configuration
# Copy this file to .env and update with your actual values

# JIRA Connection Settings
JIRA_SERVER_URL=https://your-company.atlassian.net
JIRA_API_TOKEN=your_api_token_here

# Performance Configuration
# Controls both concurrent requests and rate limiting (requests per second)
MAX_CONCURRENT_REQUESTS=2

# Logging Configuration
LOG_LEVEL=ERROR
# Set to 'true' only for debugging - will interfere with MCP stdio protocol
LOG_TO_STDOUT=false

# HTTP Timeout Settings (in seconds)
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10

# Rate Limiting Notes:
# - Start with MAX_CONCURRENT_REQUESTS=2 for testing
# - Increase gradually if no 429 errors occur
# - Different JIRA instances have different limits:
#   * Atlassian Cloud Standard: ~10 requests/second per user
#   * Atlassian Cloud Premium: Higher limits
#   * JIRA Server/Data Center: Varies by configuration
# 
# Run 'python check_rate_limits.py' to discover your limits 